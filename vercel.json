{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "server.js" },
    { "src": "/assets/(.*)",   "dest": "/assets/$1" },
    { "handle": "filesystem"                        },
    { "src": "/(.*)",          "dest": "/index.html"}
  ]
}
