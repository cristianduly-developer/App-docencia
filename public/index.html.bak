  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:Georgia,serif;background:#f1f5f9}
    #root{max-width:480px;margin:0 auto;min-height:100vh}
    .mnav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:#1a202c;display:flex;z-index:999;border-top:1px solid #2d3748}
    .mnav a{flex:1;padding:10px 4px 12px;text-align:center;color:#94a3b8;text-decoration:none;font-size:10px;font-weight:700;font-family:Georgia,serif;text-transform:uppercase;letter-spacing:.5px;display:flex;flex-direction:column;align-items:center;gap:3px}
    .mnav a.active{color:#40916c}
    .mnav a span{font-size:18px}
  </style>
</head>
<body>
  <div id="root"></div>
  <nav class="mnav">
    <a href="/" class="active"><span>🗺</span>App</a>
    <a href="/config" ><span>⚙️</span>Config</a>
    <a href="/docs" ><span>📄</span>Docs</a>
  </nav>
  <script type="text/babel" data-presets="react">

